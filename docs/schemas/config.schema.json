{
  "$defs": {
    "CheckConfig": {
      "additionalProperties": false,
      "properties": {
        "missing_layout_file": {
          "default": "error",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Missing Layout File",
          "type": "string"
        },
        "frontmatter_schema": {
          "default": "error",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Frontmatter Schema",
          "type": "string"
        },
        "missing_schema_ref": {
          "default": "error",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Missing Schema Ref",
          "type": "string"
        },
        "remote_schema_refs": {
          "default": "allow",
          "enum": [
            "allow",
            "deny",
            "allowlist"
          ],
          "title": "Remote Schema Refs",
          "type": "string"
        },
        "remote_schema_hosts": {
          "items": {
            "type": "string"
          },
          "title": "Remote Schema Hosts",
          "type": "array"
        }
      },
      "title": "CheckConfig",
      "type": "object"
    },
    "FmtConfig": {
      "additionalProperties": false,
      "description": "Resolved fmt: inline mdformat options or a path to a TOML file.",
      "properties": {
        "options": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Options"
        },
        "toml": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Toml"
        }
      },
      "title": "FmtConfig",
      "type": "object"
    },
    "GraphConfig": {
      "additionalProperties": false,
      "properties": {
        "base_iri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Base Iri"
        },
        "content_predicate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Predicate"
        },
        "include_file_extension": {
          "default": false,
          "title": "Include File Extension",
          "type": "boolean"
        },
        "implicit_types": {
          "items": {
            "type": "string"
          },
          "title": "Implicit Types",
          "type": "array"
        },
        "implicit_types_policy": {
          "default": "fallback",
          "title": "Implicit Types Policy",
          "type": "string"
        },
        "context": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context"
        }
      },
      "title": "GraphConfig",
      "type": "object"
    },
    "LinkConfig": {
      "additionalProperties": false,
      "properties": {
        "style": {
          "default": "standard",
          "title": "Style",
          "type": "string"
        },
        "renames": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Renames"
        }
      },
      "title": "LinkConfig",
      "type": "object"
    },
    "LintConfig": {
      "additionalProperties": false,
      "properties": {
        "broken_links": {
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Broken Links",
          "type": "string"
        },
        "filename_pattern": {
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Filename Pattern",
          "type": "string"
        },
        "headings": {
          "default": "off",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Headings",
          "type": "string"
        },
        "heading_levels": {
          "default": "off",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Heading Levels",
          "type": "string"
        },
        "duplicate_headings": {
          "default": "off",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Duplicate Headings",
          "type": "string"
        },
        "thematic_breaks": {
          "default": "off",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Thematic Breaks",
          "type": "string"
        },
        "link_style": {
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "off"
          ],
          "title": "Link Style",
          "type": "string"
        }
      },
      "title": "LintConfig",
      "type": "object"
    },
    "SiteConfig": {
      "additionalProperties": false,
      "properties": {
        "layout": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Layout"
        },
        "base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Base Url"
        },
        "url_style": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url Style"
        }
      },
      "title": "SiteConfig",
      "type": "object"
    },
    "SparqlServiceConfig": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "path": {
          "default": "/api/sparql",
          "title": "Path",
          "type": "string"
        }
      },
      "title": "SparqlServiceConfig",
      "type": "object"
    },
    "WikiConfig": {
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "items": {
            "format": "path",
            "type": "string"
          },
          "title": "Inputs",
          "type": "array"
        },
        "assets": {
          "anyOf": [
            {
              "items": {
                "format": "path",
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assets"
        },
        "exclude": {
          "items": {
            "type": "string"
          },
          "title": "Exclude",
          "type": "array"
        },
        "filename_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filename Pattern"
        }
      },
      "title": "WikiConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Wiki configuration: nested yaml blocks plus loader-injected config_root.",
  "properties": {
    "wiki": {
      "$ref": "#/$defs/WikiConfig"
    },
    "graph": {
      "$ref": "#/$defs/GraphConfig"
    },
    "site": {
      "$ref": "#/$defs/SiteConfig"
    },
    "link": {
      "$ref": "#/$defs/LinkConfig"
    },
    "check": {
      "$ref": "#/$defs/CheckConfig"
    },
    "lint": {
      "$ref": "#/$defs/LintConfig"
    },
    "fmt": {
      "anyOf": [
        {
          "$ref": "#/$defs/FmtConfig"
        },
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "string"
        },
        {
          "format": "path",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fmt"
    },
    "sparql_service": {
      "$ref": "#/$defs/SparqlServiceConfig"
    },
    "config_root": {
      "format": "path",
      "title": "Config Root",
      "type": "string"
    }
  },
  "title": "Config",
  "type": "object"
}
