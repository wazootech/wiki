{# wiki init scaffold — variables: wiki_base, base_url, url_style, wazoo, content_predicate, link_style #}
# Vault paths (relative to this file). See Wiki_Configuration.md.
input_dirs:
  - wiki
# asset_dirs:
#   - assets

# Site and document URIs
wiki_base: {{ wiki_base }}
base_url: {{ base_url }}
url_style: {{ url_style }}

# Filename regex (full .md name). lint.filename_pattern controls severity.
filename_pattern: "[A-Za-z0-9_()-]+\\.md"

# Glob patterns skipped when indexing (POSIX paths relative to config root).
# exclude:
#   - assets/private/**

# When set, markdown body text is added as a literal for full-text SPARQL.
{% if content_predicate %}
content_predicate: {{ content_predicate }}
{% else %}
# content_predicate: schema:articleBody
{% endif %}

# Include file extension in generated document URIs when true (default false).
# uri_ext: false

# Internal link authoring: markdown | wikilink (default markdown).
{% if link_style %}
link_style: {{ link_style }}
{% else %}
link_style: markdown
{% endif %}

# Integrity lane — `wiki check` (SHACL, routes, layout frontmatter).
check:
  forbidden_layout_keys: error
  missing_layout_file: error

# Convention lane — `wiki lint` (severities: error | warning | off).
lint:
  broken_links: warning
  filename_pattern: warning
  headings: off
  heading_levels: off
  duplicate_headings: off
  thematic_breaks: off
  link_style: warning

# Optional slug renames for `wiki link --fix-broken`.
# link_renames:
#   Old_Page_Name: New_Page_Name

# Optional SPARQL HTTP endpoint on `wiki serve` (opt-in).
# sparql_service:
#   enabled: false
#   path: /api/sparql

# Default page layout for `wiki build` / `wiki serve`.
page_layout: layouts/default.html

# Prefix map for CURIEs in frontmatter and microdata.
context:
  schema: https://schema.org/
  wiki: {{ wiki_base }}
  wazoo: {{ wazoo }}
  foaf: http://xmlns.com/foaf/0.1/
  dc: http://purl.org/dc/elements/1.1/
  dcterms: http://purl.org/dc/terms/
  sh: http://www.w3.org/ns/shacl#
  xsd: http://www.w3.org/2001/XMLSchema#

# Mechanical markdown style lives in `.mdformat.toml` beside this file — use `wiki fmt`.
