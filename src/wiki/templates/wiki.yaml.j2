{# wiki init scaffold — variables: wiki_base, base_url, url_style, site_title, content_predicate, link_style #}
vault:
  inputs:
    - wiki
  # assets:
  #   - assets
  filename_pattern: "[A-Za-z0-9_()-]+\\.md"
  # exclude:
  #   - assets/private/**

graph:
  wiki_base: {{ wiki_base }}
{% if content_predicate %}
  content_predicate: {{ content_predicate }}
{% else %}
  # content_predicate: schema:articleBody
{% endif %}
  # include_file_extension: false
  # implicit_types: [schema:TechArticle]
  # implicit_types_policy: fallback
  context:
    schema: https://schema.org/
    wiki: {{ wiki_base }}
    wazoo: https://schema.wazoo.dev/
    foaf: http://xmlns.com/foaf/0.1/
    dc: http://purl.org/dc/elements/1.1/
    dcterms: http://purl.org/dc/terms/
    sh: http://www.w3.org/ns/shacl#
    xsd: http://www.w3.org/2001/XMLSchema#

site:
  title: {{ site_title }}
  layout: layouts/default.html
  base_url: {{ base_url }}
  url_style: {{ url_style }}

link:
{% if link_style %}
  style: {{ link_style }}
{% else %}
  style: markdown
{% endif %}
  # renames:
  #   Old_Page_Name: New_Page_Name

check:
  missing_layout_file: error

lint:
  broken_links: warning
  filename_pattern: warning
  headings: off
  heading_levels: off
  duplicate_headings: off
  thematic_breaks: off
  link_style: warning

# Optional SPARQL HTTP endpoint on `wiki serve` (opt-in).
# sparql_service:
#   enabled: false
#   path: /api/sparql

fmt:
  wrap: "no"
  end_of_line: lf
  extensions: [gfm, frontmatter, wikilink]

# Pointer mode (optional TOML file relative to this file):
# fmt: .mdformat.toml
