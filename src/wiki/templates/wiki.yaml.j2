{# wiki init scaffold — variables: graph_context_wiki, site_base_url, site_url_style, site_manifest_name, graph_content_predicate, link_style, wiki_inputs, graph_base_iri, site_manifest_theme_color, graph_implicit_types, graph_implicit_types_policy, graph_include_file_extension #}

# Wiki paths, assets, and filename policy (wiki check / wiki lint).
wiki:
  # Markdown and data directories to index (relative to this file).
  inputs:
{% if wiki_inputs %}
{% for inp in wiki_inputs %}
    - {{ inp }}
{% endfor %}
{% else %}
    - wiki
{% endif %}
  # Static files for custom CSS, logos, favicons (copied on wiki build).
  assets:
    - assets
  # Full-filename regex for markdown files (lint.filename_pattern severity).
  filename_pattern: "[A-Za-z0-9_()-]+\\.md"
  # Glob patterns skipped when indexing (POSIX paths relative to config root).
  # exclude:
  #   - assets/private/**

# RDF document URIs, prefixes, and graph build settings.
graph:
{% if graph_content_predicate %}
  # Predicate for full-text body literals in SPARQL (for example schema:articleBody).
  content_predicate: {{ graph_content_predicate }}
{% else %}
  # content_predicate: schema:articleBody
{% endif %}
{% if graph_include_file_extension is not none %}
  include_file_extension: {{ 'true' if graph_include_file_extension else 'false' }}
{% else %}
  # include_file_extension: false
{% endif %}
{% if graph_implicit_types %}
  implicit_types:
{% for t in graph_implicit_types %}
    - {{ t }}
{% endfor %}
{% else %}
  # implicit_types: [schema:TechArticle]
{% endif %}
{% if graph_implicit_types_policy %}
  implicit_types_policy: {{ graph_implicit_types_policy }}
{% else %}
  # implicit_types_policy: fallback
{% endif %}
{% if graph_base_iri %}
  base_iri: {{ graph_base_iri }}
{% else %}
  # base_iri: https://example.org/docs/  # optional override; defaults to context.wiki
{% endif %}
  # CURIE prefix map for frontmatter and microdata.
  context:
    schema: https://schema.org/
    wiki: {{ graph_context_wiki }}
    wazoo: https://schema.wazoo.dev/
    foaf: http://xmlns.com/foaf/0.1/
    dc: http://purl.org/dc/elements/1.1/
    dcterms: http://purl.org/dc/terms/
    sh: http://www.w3.org/ns/shacl#
    xsd: http://www.w3.org/2001/XMLSchema#

# Page layout, URL routing, and Web App Manifest branding.
site:
  manifest:
    # Site name in layout chrome and manifest.webmanifest.
    name: {{ site_manifest_name }}
    icons:
      - src: assets/logo.svg
        sizes: "200x200"
        type: image/svg+xml
        purpose: any
{% if site_manifest_theme_color %}
    theme_color: "{{ site_manifest_theme_color }}"
{% else %}
    # theme_color: "#6366f1"
{% endif %}
    #   - src: assets/icon-512.png
    #     sizes: "512x512"
    #     type: image/png
  # Default page layout Jinja template (see Wiki Configuration → Page layout).
  layout: layouts/default.html.j2
  # URL prefix for built and served pages.
  base_url: {{ site_base_url }}
  # dir → slug/index.html; file → slug.html
  url_style: {{ site_url_style }}

# wiki link command output format and rename repair map.
link:
{% if link_style %}
  # standard Markdown or Obsidian (wiki link --apply).
  style: {{ link_style }}
{% else %}
  # standard Markdown or Obsidian (wiki link --apply).
  style: markdown
{% endif %}
  # renames:
  #   Old_Page_Name: New_Page_Name

# Integrity severities (wiki check): SHACL, JSON Schema, routes, layout files.
check:
  # Error when wazoo:layout points at a missing .html.j2 file.
  missing_layout_file: error
  # Error when frontmatter fails JSON Schema validation.
  frontmatter_schema: error
  # Error when wazoo:jsonSchema cannot be loaded (local or remote).
  missing_schema_ref: error

# Convention severities (wiki lint): links, filenames, headings.
lint:
  # Wikilinks, markdown links, fragments, assets, wiki: CURIEs.
  broken_links: warning
  # Wiki filename_pattern regex (see wiki.filename_pattern).
  filename_pattern: warning
  # ATX headings, sentence-case H2+, numbered headings.
  headings: off
  # Heading level gaps (for example H1 then H3).
  heading_levels: off
  # Duplicate heading text on one page.
  duplicate_headings: off
  # Horizontal rules used as thematic breaks in body prose.
  thematic_breaks: off
  # Obsidian wikilinks in body when link.style is markdown.
  link_style: warning

# Optional SPARQL HTTP endpoint on wiki serve (opt-in).
# sparql_service:
#   enabled: false
#   path: /api/sparql

# Markdown formatting options (wiki fmt); inline mapping or TOML path.
fmt:
  # Line wrap width (no disables wrapping).
  wrap: "no"
  # Line ending style (lf or crlf).
  end_of_line: lf
  # mdformat extensions enabled for wiki markdown.
  extensions: [gfm, frontmatter, wikilink]

# Pointer mode (optional TOML file relative to this file):
# fmt: .mdformat.toml
