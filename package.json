{
  "name": "wazootech-wiki",
  "version": "0.1.16",
  "description": "Clean, pure, idiomatic CLI for managing a semantic LLM wiki",
  "repository": {
    "type": "git",
    "url": "https://github.com/wazootech/wiki.git"
  },
  "homepage": "https://github.com/wazootech/wiki",
  "bugs": "https://github.com/wazootech/wiki/issues",
  "license": "MIT",
  "main": "./npm/dist/index.js",
  "module": "./npm/dist/index.mjs",
  "types": "./npm/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./npm/dist/index.d.ts",
      "import": "./npm/dist/index.mjs",
      "require": "./npm/dist/index.js"
    }
  },
  "bin": {
    "wiki": "npm/bin/wiki.js"
  },
  "scripts": {
    "build": "tsup npm/src/index.ts --format cjs,esm --dts --out-dir npm/dist --clean --shims --silent",
    "prepack": "npm run build",
    "postinstall": "node npm/setup.js",
    "preuninstall": "node npm/uninstall.js",
    "setup": "node npm/setup.js",
    "gendocs:python": "uv run sphinx-build -b html -c docs docs/api/python docs/assets/api/python",
    "gendocs:ts": "typedoc",
    "test:npm": "npm run build && node npm/test-setup-argv.js && node npm/test-wiki-api.js"
  },
  "files": [
    "npm/bin/",
    "npm/dist/",
    "npm/python.js",
    "npm/setup.js",
    "npm/uninstall.js",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "0.28.1",
    "tsup": "^8.3.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
